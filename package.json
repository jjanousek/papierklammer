{
  "name": "papierklammer",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-with-tui.mjs",
    "dev:watch": "pnpm --filter @papierklammer/server exec tsx ../scripts/dev-runner.ts watch",
    "dev:tui": "node scripts/dev-tui.mjs",
    "dev:once": "pnpm --filter @papierklammer/server exec tsx ../scripts/dev-runner.ts dev",
    "dev:list": "pnpm --filter @papierklammer/server exec tsx ../scripts/dev-service.ts list",
    "dev:stop": "pnpm --filter @papierklammer/server exec tsx ../scripts/dev-service.ts stop",
    "dev:server": "pnpm --filter @papierklammer/server dev",
    "dev:ui": "pnpm --filter @papierklammer/ui dev",
    "audit:demo:create": "node cli/node_modules/tsx/dist/cli.mjs scripts/audit/create-demo-cli.ts",
    "audit:instance:audit:reset": "node cli/node_modules/tsx/dist/cli.mjs scripts/audit/reset-isolated-instance.ts audit",
    "audit:instance:precompany:reset": "node cli/node_modules/tsx/dist/cli.mjs scripts/audit/reset-isolated-instance.ts precompany",
    "audit:instance:audit:bootstrap": "node cli/node_modules/tsx/dist/cli.mjs scripts/audit/bootstrap-isolated-instance.ts audit",
    "audit:instance:precompany:bootstrap": "node cli/node_modules/tsx/dist/cli.mjs scripts/audit/bootstrap-isolated-instance.ts precompany",
    "audit:instance:audit:fresh": "pnpm audit:instance:audit:reset && pnpm audit:instance:audit:bootstrap",
    "audit:instance:precompany:fresh": "pnpm audit:instance:precompany:reset && pnpm audit:instance:precompany:bootstrap",
    "audit:bootstrap": "pnpm audit:demo:create && pnpm audit:instance:audit:bootstrap && pnpm audit:instance:precompany:bootstrap",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "pnpm --filter @papierklammer/db generate",
    "db:migrate": "pnpm --filter @papierklammer/db migrate",
    "secrets:migrate-inline-env": "tsx scripts/migrate-inline-env-secrets.ts",
    "db:backup": "./scripts/backup-db.sh",
    "papierklammer": "node cli/node_modules/tsx/dist/cli.mjs cli/src/index.ts",
    "build:npm": "./scripts/build-npm.sh",
    "release": "./scripts/release.sh",
    "release:canary": "./scripts/release.sh canary",
    "release:stable": "./scripts/release.sh stable",
    "release:github": "./scripts/create-github-release.sh",
    "release:rollback": "./scripts/rollback-latest.sh",
    "check:tokens": "node scripts/check-forbidden-tokens.mjs",
    "docs:dev": "cd docs && npx mintlify dev",
    "smoke:openclaw-join": "./scripts/smoke/openclaw-join.sh",
    "smoke:openclaw-docker-ui": "./scripts/smoke/openclaw-docker-ui.sh",
    "smoke:openclaw-sse-standalone": "./scripts/smoke/openclaw-sse-standalone.sh",
    "test:e2e": "npx playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:headed": "npx playwright test --config tests/e2e/playwright.config.ts --headed",
    "evals:smoke": "cd evals/promptfoo && npx promptfoo@0.103.3 eval",
    "test:release-smoke": "npx playwright test --config tests/release-smoke/playwright.config.ts",
    "test:release-smoke:headed": "npx playwright test --config tests/release-smoke/playwright.config.ts --headed",
    "metrics:papierklammer-commits": "tsx scripts/paperclip-commit-metrics.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "patchedDependencies": {
      "embedded-postgres@18.1.0-beta.16": "patches/embedded-postgres@18.1.0-beta.16.patch"
    }
  }
}
